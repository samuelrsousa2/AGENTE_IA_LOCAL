{
  "servers": {
    "filesystem": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/workspaces"
      ],
      "env": {},
      "description": "Acesso ao sistema de arquivos externo (fora do workspace)"
    },
    "postgres": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgres://user:password@localhost:5432/mydb"
      ],
      "env": {},
      "description": "Banco de dados PostgreSQL — consultas e modificações"
    },
    "browser": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {},
      "description": "Navegador web (Puppeteer) para pesquisas e testes de UI"
    },
    "github": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      },
      "description": "GitHub API — repos, issues, pull requests"
    }
  }
}