# ==========================================================================
# .env — Configurações da IDE Agêntica (copie para .env e edite)
# ==========================================================================

# Servidor
PORT=3000
NODE_ENV=development

# Ollama (modelo de IA local)
OLLAMA_URL=http://192.168.1.2:11434

# Workspaces (pasta onde os projetos dos usuários ficam)
WORKSPACES_DIR=./workspaces

# Banco de dados SQLite
DB_PATH=./data/ide.db

# JWT Secret — MUDE ISSO EM PRODUÇÃO!
JWT_SECRET=ide-secret-mude-isso-em-producao-use-string-longa-e-aleatoria

# Conta Admin padrão (criada automaticamente no primeiro start)
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123

# Google OAuth (opcional — para produção futura)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (opcional — para cobrança futura)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# URL pública (para OAuth callbacks em produção)
# APP_URL=https://seu-dominio.com
